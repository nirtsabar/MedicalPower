  function closeOv() { ov.remove(); }
  document.getElementById('__clear_cancel').addEventListener('click', closeOv);
  document.getElementById('__clear_ok').addEventListener('click', function() { clearData(); closeOv(); });
  ov.addEventListener('click', e => { if (e.target === ov) closeOv(); });
}

function clearData() {
  STATE.elements.forEach(el => {
    const cel = document.getElementById('cel-' + el.id);
    if (!cel) return;
    if (el.type === 'field-checkbox') {
      el.checked = false;
      const box = cel.querySelector('.checkbox-box');
      if (box) box.classList.remove('checked');
    } else if (el.type === 'field-circle-choice') {
      el.checked = false;
      const cw = cel.querySelector('.circle-choice-el');
      if (cw) cw.style.borderColor = 'transparent';
    } else if (el.type === 'field-date') {
      cel.querySelectorAll('.field-real-input').forEach(inp => inp.value = '');
    } else {
      const inp = cel.querySelector('.field-real-input, .field-real-select');
      if (inp) { inp.value = el.defaultValue || ''; inp.classList.remove('id-valid','id-invalid','id-filled','id-valid-blur'); }
    }
  });
  try { localStorage.removeItem(LS_KEY); } catch(e) {}
  showToast('הנתונים נוקו');
}

// ── Auto-save / restore fill values via localStorage ──
const LS_KEY = 'fill_' + encodeURIComponent(STATE.meta.name || 'form');

function collectFillValues() {
  const vals = {};
  STATE.elements.forEach(el => {
    const cel = document.getElementById('cel-' + el.id);
    if (!cel) return;
    if (el.type === 'field-checkbox' || el.type === 'field-circle-choice') {
      vals[el.id] = { checked: el.checked };
    } else if (el.type === 'field-date') {
      const inputs = cel.querySelectorAll('.field-real-input');
      const v = [inputs[0]?inputs[0].value:'', inputs[1]?inputs[1].value:'', inputs[2]?inputs[2].value:''].join('/');
      vals[el.id] = { value: v };
    } else {
      const inp = cel.querySelector('.field-real-input, .field-real-select');
      if (inp) vals[el.id] = { value: inp.value };
    }
  });
  return vals;
}

function restoreFillValues(vals) {
  if (!vals) return;
  STATE.elements.forEach(el => {
    const v = vals[el.id];
    if (!v) return;
    const cel = document.getElementById('cel-' + el.id);
    if (!cel) return;
    if (el.type === 'field-checkbox') {
      if (typeof v.checked !== 'undefined') {
        el.checked = v.checked;
        const box = cel.querySelector('.checkbox-box');
        if (box) box.classList.toggle('checked', el.checked);
      }
    } else if (el.type === 'field-circle-choice') {
      if (typeof v.checked !== 'undefined') {
        el.checked = v.checked;
        const cw = cel.querySelector('.circle-choice-el');
        if (cw) cw.style.borderColor = el.checked ? (el.borderColor || '#111111') : 'transparent';
      }
    } else if (el.type === 'field-date' && typeof v.value !== 'undefined') {
      const parts = v.value.split('/');
      const inputs = cel.querySelectorAll('.field-real-input');
      if (inputs[0]) inputs[0].value = parts[0]||'';
      if (inputs[1]) inputs[1].value = parts[1]||'';
      if (inputs[2]) inputs[2].value = parts[2]||'';
    } else {
      const inp = cel.querySelector('.field-real-input, .field-real-select');
      if (inp && typeof v.value !== 'undefined') inp.value = v.value;
    }
  });
}

function autoSave() {
  try { localStorage.setItem(LS_KEY, JSON.stringify(collectFillValues())); } catch(e) {}
}

// Restore on load
try {
  const saved = localStorage.getItem(LS_KEY);
  if (saved) restoreFillValues(JSON.parse(saved));
} catch(e) {}

// Wire save on every interaction
document.getElementById('pages-container').addEventListener('input', autoSave);
document.getElementById('pages-container').addEventListener('change', autoSave);
document.getElementById('pages-container').addEventListener('click', () => setTimeout(autoSave, 0));
