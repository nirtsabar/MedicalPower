function applyInputFontStyles(dom, el) {
  dom.style.fontSize=(el.inputFontSize||13)+'px';
  dom.style.fontFamily=el.inputFontFamily||'inherit';
  dom.style.color=el.inputColor||'#1a1916';
  dom.style.fontWeight=el.inputFontWeight||'400';
  dom.style.fontStyle=el.inputFontStyle||'normal';
  dom.style.textDecoration=el.inputTextDecoration||'none';
  if(el.inputDir&&el.inputDir!=='inherit') dom.dir=el.inputDir;
  if(el.inputAlign) { dom.style.textAlign=el.inputAlign; dom.style.direction=STATE.meta.dir; }
}

function setupLinkedFields() {
  _depMap={};
  STATE.elements.forEach(el => {
    if (!el.linkedTo) return;
    if (!_depMap[el.linkedTo]) _depMap[el.linkedTo]=[];
    _depMap[el.linkedTo].push(el);
  });
  Object.keys(_depMap).forEach(originId => {
    const origin=STATE.elements.find(e=>e.id===originId); if(!origin) return;
    const cel=document.getElementById('cel-'+originId); if(!cel) return;
    if (origin.type==='field-checkbox'||origin.type==='field-circle-choice') {
      if(cel.dataset.syncBound) return; cel.dataset.syncBound='1';
      cel.addEventListener('click',()=>propagateLinked(originId,origin.checked));
    } else {
      const inp=cel.querySelector('.field-real-input, .field-real-select');
      if(!inp||inp.dataset.syncBound) return; inp.dataset.syncBound='1';
      inp.addEventListener('input',()=>propagateLinked(originId,inp.value));
      inp.addEventListener('change',()=>propagateLinked(originId,inp.value));
    }
  });
}

function applyTabOrder() {
  const fieldTypes=['field-text','field-textarea','field-select','field-checkbox','field-id','field-tel','field-year','field-int','field-day','field-month','field-date','field-date-btn','field-circle-choice'];
  function computeTabOrder(page){
    const els=STATE.elements.filter(e=>e.page===page&&fieldTypes.includes(e.type)&&!e.excludeFromTab);
    const manual=els.filter(e=>e.tabOrder!=null&&e.tabOrder!=='');
    const auto=els.filter(e=>e.tabOrder==null||e.tabOrder==='');
    const rows=[];
    [...auto].sort((a,b)=>a.y-b.y).forEach(el=>{
      const row=rows.find(r=>Math.abs(r.refY-el.y)<=10);
      if(row)row.els.push(el); else rows.push({refY:el.y,els:[el]});
    });
    const isRtl=STATE.meta.dir==='rtl';
    rows.forEach(row=>row.els.sort((a,b)=>isRtl?b.x-a.x:a.x-b.x));
    const autoSeq=rows.flatMap(r=>r.els);
    const merged=[...autoSeq];
    [...manual].sort((a,b)=>+a.tabOrder-+b.tabOrder).forEach(el=>{
      const idx=merged.findIndex(e=>e.id===el.id); if(idx!==-1)merged.splice(idx,1);
      merged.splice(Math.max(0,Math.min(+el.tabOrder-1,merged.length)),0,el);
    });
    return merged;
  }
  let tabIdx=1, lastFocusable=null;
  const focusables=[];
  for (let p=1;p<=STATE.pages;p++) {
    computeTabOrder(p).forEach(el=>{
      const cel=document.getElementById('cel-'+el.id); if(!cel) return;
      if(el.type==='field-checkbox'||el.type==='field-circle-choice'){
        const sel=el.type==='field-checkbox'?'.checkbox-el':'.circle-choice-el';
        const wrap=cel.querySelector(sel); if(!wrap) return;
        wrap.tabIndex=tabIdx++;
        wrap.addEventListener('keydown',function(e){
          if(e.key===' '||e.key==='x'||e.key==='X'||e.key==='v'||e.key==='V'){e.preventDefault();if(!el.locked)wrap.click();}
          else if(e.key==='Enter'){e.preventDefault();advanceFocus(wrap);}
        });
        focusables.push(wrap); lastFocusable=wrap;
      } else {
        const inp=cel.querySelector('.field-real-input, .field-real-select');
        if(!inp) return; inp.tabIndex=tabIdx++;
        const elType=el.type, maxR=el.maxRows||3;
        inp.addEventListener('keydown',function(e){
          if(e.key!=='Enter') return;
          if(elType==='field-select') return;
          if(elType==='field-textarea'){if(inp.value.split('\n').length<maxR)return;e.preventDefault();advanceFocus(inp);}
          else{e.preventDefault();advanceFocus(inp);}
        });
        focusables.push(inp); lastFocusable=inp;
      }
    });
  }
  function advanceFocus(cur){const i=focusables.indexOf(cur);if(i===-1)return;if(i===focusables.length-1)showEndOfFormAlert();else focusables[i+1].focus();}
  if(lastFocusable){lastFocusable.addEventListener('keydown',function(e){if(e.key==='Tab'&&!e.shiftKey){e.preventDefault();showEndOfFormAlert();}});}
}

let toastTimer;
function showToast(msg){
  let t=document.getElementById('toast');
  if(!t){t=document.createElement('div');t.id='toast';t.style.cssText='position:fixed;bottom:20px;right:20px;background:#1a1916;color:#fff;padding:8px 16px;border-radius:6px;font-size:13px;z-index:9999;opacity:0;transition:opacity .2s;';document.body.appendChild(t);}
  t.textContent=msg; t.style.opacity='1';
  clearTimeout(toastTimer); toastTimer=setTimeout(()=>t.style.opacity='0',2200);
}

function showEndOfFormAlert(){
  const ex=document.getElementById('eof-alert'); if(ex)ex.remove();
  const alert=document.createElement('div'); alert.id='eof-alert';
  alert.innerHTML='<div style="font-size:15px;font-weight:700;margin-bottom:6px;">סוף הטופס ✓</div><div style="font-size:12.5px;margin-bottom:14px;opacity:.85;">כל השדות מולאו.</div><button onclick="doPrint();document.getElementById(\'eof-alert\').remove();" style="height:34px;padding:0 20px;border-radius:5px;border:none;background:#fff;color:#181714;font-size:13px;font-weight:700;cursor:pointer;">🖨 PDF</button>';
  alert.style.cssText='position:fixed;bottom:32px;left:50%;transform:translateX(-50%);background:#181714;color:#fff;padding:16px 24px;border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,.22);z-index:9500;text-align:center;animation:eof-in .2s ease;';
  document.body.appendChild(alert);
  const dismiss=e=>{if(!alert.contains(e.target)){alert.remove();document.removeEventListener('mousedown',dismiss);}};
  document.addEventListener('mousedown',dismiss);
  document.addEventListener('keydown',function onKey(e){if(e.key==='Escape'){alert.remove();document.removeEventListener('keydown',onKey);}});
}

