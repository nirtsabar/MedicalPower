<style>
:root {
  --bg: #f0ede8; --surface: #fafaf8; --border: #dedad3; --border-strong: #c4bfb7;
  --text: #181714; --text-muted: #7a7670; --text-faint: #b0ada6;
  --accent: #181714; --accent-blue: #2563eb; --success: #16a34a;
  --a4-w: 794px; --a4-h: 1123px; --page-gap: 32px;
  --shadow-lg: 0 8px 32px rgba(0,0,0,.14);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; font-family: 'Segoe UI', Arial, sans-serif; background: var(--bg); color: var(--text); }
body { display: flex; flex-direction: column; align-items: unset; min-width: fit-content; overflow-x: auto; }

#toolbar {
  position: fixed; top: 0; left: 0; right: 0; width: 100%; min-width: 100vw; height: 50px;
  background: var(--surface); border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 16px; z-index: 100;
  flex-shrink: 0;
}
#toolbar h1 { font-size: 14px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 50vw; }
.tb-btn {
  display: flex; align-items: center; gap: 5px; height: 36px; padding: 0 12px;
  border: 1px solid var(--border); border-radius: 4px; background: var(--surface);
  font-size: 12px; font-weight: 500; cursor: pointer; color: var(--text);
  transition: background .1s; white-space: nowrap; flex-shrink: 0;
}
.tb-btn:hover { background: #e8e4de; }
.tb-btn.primary { background: var(--accent); color: #fff; border-color: var(--accent); }
.tb-btn.primary:hover { opacity: .85; }

#canvas-area {
  margin-top: 0; padding: var(--page-gap); padding-top: calc(50px + var(--page-gap));
  display: flex; flex-direction: column; align-items: center; min-height: 100%;
  overflow-x: visible; margin-left: auto; margin-right: auto;
}
.page-wrapper { position: relative; margin-bottom: var(--page-gap); }
.page-num { position: absolute; bottom: -22px; left: 50%; transform: translateX(-50%); font-size: 11px; color: var(--text-faint); }
.a4-page { width: var(--a4-w); height: var(--a4-h); background: #fff; position: relative; overflow: hidden; box-shadow: var(--shadow-lg); border: 1px solid var(--border); }

.canvas-el { position: absolute; display: flex; justify-content: center; align-items: center; }
.bg-image-el { cursor: default; left: 0 !important; top: 0 !important; width: 100% !important; height: 100% !important; z-index: 0; }
.bg-image-el img { width: 100%; height: 100%; display: block; pointer-events: none; }
.text-el { width: 100%; height: 100%; overflow: hidden; display: flex; align-items: center; pointer-events: none; }
.text-el span { display: block; width: 100%; }

.field-el { width: 100%; height: 100%; display: flex; flex-direction: column; justify-content: center; gap: 4px; pointer-events: all; cursor: default; }
.field-label { font-size: 12px; font-weight: 600; color: #333; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.field-help { font-size: 11px; color: #888; }
.field-real-input { flex: 1; min-height: 16px; border: 1px solid transparent; border-radius: 4px; padding: 0; font-size: 12px; font-family: inherit; resize: none; outline: none; background: transparent; transition: border-color .15s; }
.field-real-input:hover { border-color: #ccc; }
.field-real-input:focus { border-color: var(--accent-blue); box-shadow: 0 0 0 2px rgba(37,99,235,.15); }
.field-real-select { flex: 1; height: 18px; border: 1px solid transparent; border-radius: 4px; padding: 0; font-size: 12px; font-family: inherit; outline: none; background: transparent; transition: border-color .15s; -webkit-appearance: none; appearance: none; }
.field-real-select:hover, .field-real-select:focus { -webkit-appearance: auto; appearance: auto; }
.field-real-select:hover { border-color: #ccc; }
.field-real-select:focus { border-color: var(--accent-blue); }
.field-real-input.linked-readonly, .field-real-select.linked-readonly { cursor: not-allowed; }

.checkbox-el { width: 100%; height: 100%; display: flex; align-items: center; gap: 10px; pointer-events: all; cursor: pointer; }
.checkbox-el:focus { outline: 2px solid var(--accent-blue); outline-offset: 2px; border-radius: 3px; }
.checkbox-box { flex-shrink: 0; border-radius: 4px; border: 2px solid #555; background: #fff; display: flex; align-items: center; justify-content: center; transition: background .15s, border-color .15s; position: relative; }
.checkbox-box.checked { background: #fff; border-color: #1a1916; }
.checkbox-box.checked::after { content: ''; display: block; width: 38%; height: 62%; border-right: 2.5px solid #1a1916; border-bottom: 2.5px solid #1a1916; transform: rotate(45deg) translate(-10%, -10%); }

.circle-choice-el { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; box-sizing: border-box; position: relative; pointer-events: all; cursor: pointer; transition: border-color .15s; }
.date-btn-el { width:100%;height:100%;display:flex;align-items:center;justify-content:center;gap:4px;border:1.5px dashed #2563eb;border-radius:6px;font-size:11px;font-weight:600;color:#2563eb;cursor:pointer;background:rgba(37,99,235,.05); }
.date-btn-el.interactive:hover { background:rgba(37,99,235,.1); }
.date-action-btn { height:22px;padding:0 7px;border-radius:4px;border:1px solid #2563eb;background:transparent;color:#2563eb;font-size:10px;font-weight:600;cursor:pointer;white-space:nowrap; }
.date-action-btn:hover { background:rgba(37,99,235,.15); }
.date-action-btn.clear { border-color:#aaa;color:#888;font-size:12px;padding:0 5px; }
.date-action-btn.clear:hover { background:rgba(0,0,0,.06);border-color:#888;color:#444; }
.date-sub-inputs { display:flex;align-items:center;gap:2px;width:100%;justify-content:center; }
.date-sub-inputs input { border:none;border-bottom:1px solid #aaa;background:transparent;outline:none;text-align:center;font-family:inherit;padding:0;min-width:0; }
.date-sub-inputs input:focus { border-bottom-color:#2563eb; }
.date-sep { color:#888;font-size:0.9em; }
.date-today-btn { flex-shrink:0;height:20px;padding:0 5px;border-radius:3px;border:1px solid #2563eb;background:transparent;color:#2563eb;font-size:10px;cursor:pointer;white-space:nowrap; }
.date-today-btn:hover { background:rgba(37,99,235,.1); }
.circle-choice-el:focus { outline: 2px solid var(--accent-blue); outline-offset: 2px; }

.field-real-input.id-filled:focus { border-color: #a07850 !important; }
.field-real-input.id-invalid:focus { border-color: #dc2626 !important; }
.field-real-input.id-valid:focus { border-color: #16a34a !important; }
.field-real-input.id-valid-blur { border-color: transparent !important; }

.is-linked:not(:hover) .field-real-input.linked-readonly,
.is-linked:not(:hover) .field-real-select.linked-readonly { border-color: transparent !important; }

@keyframes eof-in { from { opacity:0; transform:translateX(-50%) translateY(12px); } to { opacity:1; transform:translateX(-50%) translateY(0); } }

@media print {
  @page { margin: 0; size: A4 portrait; }
  #toolbar, .date-btn-el { display: none !important; }
  #canvas-area { margin-top: 0; padding: 0; display: block; background: #fff; }
  .page-wrapper { page-break-after: always; margin: 0; }
  .page-num { display: none; }
  .a4-page { width: 210mm; height: 297mm; box-shadow: none; border: none; overflow: visible; page-break-inside: avoid; }
  *, *::before, *::after { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
  .field-real-input, .field-real-select { border: none !important; border-radius: 0 !important; background: transparent !important; box-shadow: none !important; padding: 0 !important; -webkit-appearance: none; appearance: none; }
  .field-real-input::placeholder { color: transparent !important; }
  .field-real-input:placeholder-shown { color: transparent !important; }
  .checkbox-box { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
}
</style>
