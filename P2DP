// ── Scale-to-fit for small screens ──
function applyScale() {
  const wrapper = document.getElementById('scale-wrapper');
  const pageW = 794;
  const padding = 32;
  const available = window.innerWidth - padding;
  const scale = available < pageW ? available / pageW : 1;
  wrapper.style.transform = 'scale(' + scale + ')';
  // Adjust canvas-area height to account for scaling (avoids extra scroll space)
  const container = document.getElementById('pages-container');
  const naturalH = container.offsetHeight;
  wrapper.style.height = naturalH + 'px';
  document.getElementById('canvas-area').style.minHeight = (naturalH * scale) + 'px';
}

applyScale();
window.addEventListener('resize', applyScale);

// ── Share / Download PDF ──
function loadScript(src) {
  return new Promise((resolve, reject) => {
    if (document.querySelector('script[src="'+src+'"]')) { resolve(); return; }
    const s = document.createElement('script');
    s.src = src; s.onload = resolve; s.onerror = reject;
    document.head.appendChild(s);
  });
}

async function sharePdf() {
  const btn = document.getElementById('btn-share');
  btn.disabled = true;
  btn.textContent = '⏳ מכין...';
  try {
    await loadScript('https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js');
    await loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js');
    const { jsPDF } = window.jspdf;
    const pdf = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
    const pages = document.querySelectorAll('.a4-page');
    for (let i = 0; i < pages.length; i++) {
      if (i > 0) pdf.addPage();
      const canvas = await html2canvas(pages[i], {
        scale: 2,
        useCORS: true,
        allowTaint: true,
        backgroundColor: '#ffffff',
        width: 794,
        height: 1123,
        onclone: (clonedDoc) => {
          const toolbar = clonedDoc.getElementById('toolbar');
          if (toolbar) toolbar.style.display = 'none';
          // Hide today/clear buttons — not visible in print
          clonedDoc.querySelectorAll('.date-btn-el').forEach(el => el.style.display = 'none');
          const ca = clonedDoc.getElementById('canvas-area');
          if (ca) { ca.style.padding = '0'; ca.style.margin = '0'; ca.style.marginTop = '0'; }
          const clonedPages = clonedDoc.querySelectorAll('.a4-page');
          if (clonedPages[i]) {
            const pw = clonedPages[i].parentElement;
            if (pw) { pw.style.margin = '0'; pw.style.padding = '0'; }
            clonedPages[i].style.position = 'fixed';
            clonedPages[i].style.top = '0';
            clonedPages[i].style.left = '0';
            clonedPages[i].style.margin = '0';
            clonedPages[i].style.overflow = 'visible';
            clonedPages[i].querySelectorAll('.bg-image-el img').forEach(img => {
              const parent = img.parentElement;
              const fit = img.style.objectFit || 'cover';
              const posX = img.style.objectPosition ? img.style.objectPosition.split(' ')[0] : '50%';
              const posY = img.style.objectPosition ? img.style.objectPosition.split(' ')[1] : '50%';
              const div = clonedDoc.createElement('div');
              div.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;' +
                'background-image:url(' + JSON.stringify(img.src) + ');' +
                'background-size:' + (fit==='fill'?'100% 100%':fit==='none'?'auto':fit) + ';' +
                'background-position:' + posX + ' ' + posY + ';' +
                'background-repeat:no-repeat;' +
                'opacity:' + (img.style.opacity||1) + ';';
              parent.replaceChild(div, img);
            });
            // Replace textareas with divs so html2canvas preserves line breaks
            clonedPages[i].querySelectorAll('textarea.field-real-input').forEach(ta => {
              const div = clonedDoc.createElement('div');
              div.style.cssText = ta.style.cssText +
                ';white-space:pre-wrap;word-break:break-word;overflow:hidden;' +
                'font-size:' + getComputedStyle(ta).fontSize +
                ';font-family:' + getComputedStyle(ta).fontFamily +
                ';color:' + getComputedStyle(ta).color +
                ';text-align:' + getComputedStyle(ta).textAlign +
                ';background:transparent;';
              div.textContent = ta.value;
              ta.parentElement.replaceChild(div, ta);
            });
            // Replace text inputs with divs so html2canvas vertically centers text correctly
            clonedPages[i].querySelectorAll('input.field-real-input').forEach(inp => {
              const cs = getComputedStyle(inp);
              const div = clonedDoc.createElement('div');
              div.style.cssText =
                'display:flex;align-items:center;' +
                'width:100%;height:' + cs.height + ';' +
                'font-size:' + cs.fontSize + ';' +
                'font-family:' + cs.fontFamily + ';' +
                'color:' + cs.color + ';' +
                'font-weight:' + cs.fontWeight + ';' +
                'font-style:' + cs.fontStyle + ';' +
                'text-align:' + cs.textAlign + ';' +
                'direction:' + cs.direction + ';' +
                'background:transparent;' +
                'overflow:hidden;white-space:nowrap;';
              div.textContent = inp.value;
              inp.parentElement.replaceChild(div, inp);
            });
            // Replace selects with divs showing selected option text
            clonedPages[i].querySelectorAll('select.field-real-select').forEach(sel => {
              const cs = getComputedStyle(sel);
              const selected = sel.options[sel.selectedIndex];
              const div = clonedDoc.createElement('div');
              div.style.cssText =
                'display:flex;align-items:center;' +
                'width:100%;height:' + cs.height + ';' +
                'font-size:' + cs.fontSize + ';' +
                'font-family:' + cs.fontFamily + ';' +
                'color:' + cs.color + ';' +
                'text-align:' + cs.textAlign + ';' +
                'background:transparent;' +
                'overflow:hidden;white-space:nowrap;';
              div.textContent = selected && selected.value ? selected.textContent : '';
              sel.parentElement.replaceChild(div, sel);
            });
          }
        }
      });
      const imgData = canvas.toDataURL('image/jpeg', 1.0);
      pdf.addImage(imgData, 'JPEG', 0, 0, 210, 297);
    }
    const rawName = (STATE.meta.name || 'form').replace(/[/\\:*?"<>|]/g, '_');
    const filename = rawName + '.pdf';
    // Transliterate Hebrew to ASCII for WhatsApp sharing
    const _heMap = {'א':'a','ב':'b','ג':'g','ד':'d','ה':'h','ו':'v','ז':'z','ח':'ch','ט':'t',
      'י':'y','כ':'k','ך':'k','ל':'l','מ':'m','ם':'m','נ':'n','ן':'n','ס':'s','ע':'a',
      'פ':'p','ף':'p','צ':'ts','ץ':'ts','ק':'k','ר':'r','ש':'sh','ת':'t'};
    const translitHe = s => s.split('').map(c => _heMap[c] !== undefined ? _heMap[c] : c).join('');
    const defaultShareName = translitHe(rawName).replace(/[^ -~]/g, '').trim().replace(/s+/g, '_') || 'form';

    // Ask user for share filename
    const chosenName = await new Promise(resolve => {
      const ov = document.createElement('div');
      ov.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9900;display:flex;align-items:center;justify-content:center;';
      const box = document.createElement('div');
      box.style.cssText = 'background:#fff;border-radius:10px;padding:24px 24px 18px;max-width:360px;width:92%;box-shadow:0 8px 32px rgba(0,0,0,.22);direction:rtl;';
      const label = document.createElement('div');
      label.textContent = 'שם הקובץ לשיתוף:';
      label.style.cssText = 'font-size:14px;font-weight:600;margin-bottom:8px;';
      const inp = document.createElement('input');
      inp.type = 'text';
      inp.value = defaultShareName;
      inp.style.cssText = 'width:100%;height:36px;border:1px solid #ccc;border-radius:6px;padding:0 10px;font-size:14px;direction:ltr;box-sizing:border-box;margin-bottom:10px;';
      const note = document.createElement('div');
      note.textContent = 'שים לב: בשיתוף ל-WhatsApp אותיות עבריות וערביות בשם הקובץ אינן מועברות כראוי — מומלץ להשתמש בשם באנגלית.';
      note.style.cssText = 'font-size:11.5px;color:#888;line-height:1.5;margin-bottom:16px;';
      const btns = document.createElement('div');
      btns.style.cssText = 'display:flex;gap:8px;';
      const cancelBtn = document.createElement('button');
      cancelBtn.textContent = 'ביטול';
      cancelBtn.style.cssText = 'flex:1;height:36px;border-radius:6px;border:1px solid #ddd;background:#f5f5f5;font-size:13px;cursor:pointer;';
      const okBtn = document.createElement('button');
      okBtn.textContent = 'שתף';
      okBtn.style.cssText = 'flex:2;height:36px;border-radius:6px;border:none;background:#181714;color:#fff;font-size:13px;font-weight:600;cursor:pointer;';
      cancelBtn.addEventListener('click', () => { ov.remove(); resolve(null); });
      okBtn.addEventListener('click', () => { ov.remove(); resolve(inp.value.trim() || defaultShareName); });
      inp.addEventListener('keydown', e => { if (e.key === 'Enter') { ov.remove(); resolve(inp.value.trim() || defaultShareName); } });
      btns.appendChild(cancelBtn); btns.appendChild(okBtn);
      box.appendChild(label); box.appendChild(inp); box.appendChild(note); box.appendChild(btns);
      ov.appendChild(box);
      document.body.appendChild(ov);
      setTimeout(() => { inp.focus(); inp.select(); }, 50);
    });

    if (!chosenName) { btn.disabled = false; btn.textContent = '📤 שתף PDF'; return; }

    const shareFilename = chosenName.replace(/[/\\:*?"<>|]/g, '_') + '.pdf';
    const blob = pdf.output('blob');
    const file = new File([blob], shareFilename, { type: 'application/pdf' });
    if (navigator.canShare && navigator.canShare({ files: [file] })) {
      await navigator.share({ files: [file], title: STATE.meta.name || 'טופס' });
    } else {
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.setAttribute('download', shareFilename);
      document.body.appendChild(a);
      a.click();
      setTimeout(() => { document.body.removeChild(a); URL.revokeObjectURL(url); }, 200);
    }
  } catch(e) {
    alert('שגיאה ביצירת PDF: ' + e.message);
  } finally {
    btn.disabled = false; btn.textContent = '📤 שתף PDF';
  }
}

