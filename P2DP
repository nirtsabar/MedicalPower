let _aboutLang = 'he';

function showAbout(fromAuto) {
  if (document.getElementById('__about_ov')) return;
  const ov = document.createElement('div');
  ov.id = '__about_ov';
  ov.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9900;display:flex;align-items:center;justify-content:center;';
  const box = document.createElement('div');
  box.id = '__about_box';
  box.style.cssText = 'background:#fff;border-radius:12px;padding:28px 28px 22px;max-width:380px;width:92%;box-shadow:0 8px 32px rgba(0,0,0,.22);';
  ov.appendChild(box);
  document.body.appendChild(ov);
  ov.addEventListener('click', e => { if (e.target === ov) ov.remove(); });
  renderAboutContent();
}

function renderAboutContent() {
  const box = document.getElementById('__about_box');
  if (!box) return;
  const t = _aboutTexts[_aboutLang];
  const langs = [{k:'he',l:'עב'},{k:'en',l:'EN'},{k:'ru',l:'РУ'},{k:'ar',l:'عر'}];
  box.dir = t.dir;
  box.innerHTML = '';

  // Language buttons row
  const langRow = document.createElement('div');
  langRow.style.cssText = 'display:flex;gap:5px;margin-bottom:16px;justify-content:' + (t.dir==='rtl'?'flex-start':'flex-end') + ';';
  langs.forEach(function(lk) {
    const btn = document.createElement('button');
    btn.textContent = lk.l;
    btn.style.cssText = 'height:26px;min-width:32px;padding:0 6px;border-radius:5px;border:1px solid #ccc;' +
      'background:' + (_aboutLang===lk.k?'#181714':'#f5f5f5') + ';' +
      'color:' + (_aboutLang===lk.k?'#fff':'#333') + ';' +
      'font-size:11px;font-weight:700;cursor:pointer;';
    btn.addEventListener('click', function() { _aboutLang = lk.k; renderAboutContent(); });
    langRow.appendChild(btn);
  });
  box.appendChild(langRow);

  // Text paragraphs
  [
    {text: t.p1, style: 'font-size:17px;line-height:1.65;margin-bottom:12px;color:#111;'},
    {text: t.p2, style: 'font-size:16px;color:#222;line-height:1.6;margin-bottom:12px;'},
    {text: t.p3, style: 'font-size:15px;color:#333;line-height:1.6;margin-bottom:20px;border-top:1px solid #eee;padding-top:14px;', icon: t.icon}
  ].forEach(function(item) {
    const p = document.createElement('p');
    p.style.cssText = item.style;
    if (item.icon) {
      // Split on placeholder and insert icon span
      const parts = item.text.split('___ICON___');
      p.appendChild(document.createTextNode(parts[0]));
      const iconSpan = document.createElement('span');
      iconSpan.textContent = item.icon;
      iconSpan.style.cssText = 'display:inline-block;vertical-align:middle;font-size:15px;margin:0 3px;';
      p.appendChild(iconSpan);
      if (parts[1]) p.appendChild(document.createTextNode(parts[1]));
    } else {
      p.textContent = item.text;
    }
    box.appendChild(p);
  });

  // OK button
  const okBtn = document.createElement('button');
  okBtn.textContent = t.ok;
  okBtn.style.cssText = 'width:100%;height:38px;border-radius:7px;border:none;background:#181714;color:#fff;font-size:14px;font-weight:600;cursor:pointer;';
  okBtn.addEventListener('click', function() {
    document.getElementById('__about_ov').remove();
    try { localStorage.setItem('__about_seen','1'); } catch(e) {}
