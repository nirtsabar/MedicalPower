function doPrint() {
  // Temporarily hide placeholder text in empty selects
  const empties = [];
  document.querySelectorAll('.field-real-select').forEach(sel => {
    if (!sel.value) { sel.style.color = 'transparent'; empties.push(sel); }
  });
  document.body.classList.add('printing-with-data');
  window.print();
  setTimeout(() => {
    document.body.classList.remove('printing-with-data');
    empties.forEach(sel => sel.style.color = '');
  }, 1000);
}

function resolveYear(val) {
  if (val === undefined || val === null || val === '') return null;
  if (typeof val === 'number') return val;
  const s = String(val).trim();
  const cur = new Date().getFullYear();
  const m = s.match(/^current\s*([+\-])\s*(\d+)$/);
  if (m) return cur + (m[1] === '+' ? 1 : -1) * +m[2];
  if (s === 'current') return cur;
  const n = +s; return isNaN(n) ? null : n;
}

function validateIsraeliId(id) {
  const s = String(id).padStart(9,'0');
  if (!/^\d{9}$/.test(s)) return false;
  let sum = 0;
  for (let i = 0; i < 9; i++) { let d = +s[i] * ((i%2)+1); if (d>9) d-=9; sum+=d; }
  return sum % 10 === 0;
}

function validateIsraeliPhone(val) {
  const d = val.replace(/[\s\-\.]/g, '');
  if (/^05\d{8}$/.test(d)) return true;
  if (/^\+9725\d{8}$/.test(d)) return true;
  if (/^\+97205\d{8}$/.test(d)) return true;
  if (/^0[2-46-9]\d{7}$/.test(d)) return true;
  return false;
}

let _depMap = {};
function propagateLinked(originId, value, visited) {
  visited = visited || new Set();
  if (visited.has(originId)) return;
  visited.add(originId);
  (_depMap[originId] || []).forEach(dep => {
    const cel = document.getElementById('cel-'+dep.id);
    if (!cel) return;
    if (dep.type === 'field-checkbox') {
      dep.checked = value;
      const box = cel.querySelector('.checkbox-box');
      if (box) box.classList.toggle('checked', !!value);
    } else if (dep.type === 'field-circle-choice') {
      dep.checked = value;
      const cw = cel.querySelector('.circle-choice-el');
      if (cw) cw.style.borderColor = value ? (dep.borderColor||'#111111') : 'transparent';
    } else {
      const inp = cel.querySelector('.field-real-input, .field-real-select');
      if (inp) inp.value = value;
    }
    propagateLinked(dep.id, value, visited);
  });
}

function renderPages() {
  const container = document.getElementById('pages-container');
  container.innerHTML = '';
  container.dir = STATE.meta.dir || 'rtl';
  const isFill = true;
  for (let p = 1; p <= STATE.pages; p++) {
    const wrapper = document.createElement('div');
    wrapper.className = 'page-wrapper';
    const page = document.createElement('div');
    page.className = 'a4-page';
    page.id = 'page-'+p;
    const els = STATE.elements.filter(e => e.page === p).sort((a,b) => a.zIndex - b.zIndex);
    els.forEach(el => {
      const div = document.createElement('div');
      div.className = 'canvas-el' + (el.type === 'bg-image' ? ' bg-image-el' : '');
      div.id = 'cel-'+el.id;
      div.dataset.id = el.id;
      if (el.type !== 'bg-image') {
        div.style.left = el.x+'px'; div.style.top = el.y+'px';
        div.style.width = el.w+'px'; div.style.height = el.h+'px';
      }
      div.style.zIndex = el.zIndex;

      // External label
      const labelTypes = ['field-text','field-textarea','field-select','field-id','field-tel','field-year','field-int','field-checkbox','field-circle-choice'];
      if (labelTypes.includes(el.type) && el.showLabel && el.label) {
        const extLbl = document.createElement('div');
        extLbl.className = 'field-label';
        extLbl.textContent = el.label + (el.required ? ' *' : '');
        extLbl.style.textAlign = el.labelAlign || el.inputAlign || 'center';
        extLbl.style.pointerEvents = 'none';
        div.appendChild(extLbl);
      }

      const inner = createInner(el);
      if (inner) div.appendChild(inner);
      page.appendChild(div);
    });
    const pnum = document.createElement('div');
    pnum.className = 'page-num';
    pnum.textContent = p + ' / ' + STATE.pages;
    // Watermark on first page only
    if (p === 1) {
      const wm = document.createElement('div');
      wm.style.cssText = 'position:absolute;bottom:6px;left:8px;font-size:8px;color:#bbb;pointer-events:none;z-index:9999;line-height:1.3;';
      wm.textContent = 'אוטומציה ע"י ד"ר ניר צבר • Version_135';
      page.appendChild(wm);
    }
    wrapper.appendChild(page);
    wrapper.appendChild(pnum);
    container.appendChild(wrapper);
  }
}

function createInner(el) {
  if (el.type === 'bg-image') {
    if (!el.src) return null;
    const img = document.createElement('img');
    img.src = el.src;
    img.style.cssText = 'width:100%;height:100%;display:block;pointer-events:none;object-fit:'+
      (el.fit==='stretch'?'fill':el.fit==='none'?'none':el.fit)+
      ';object-position:'+el.offsetX+'% '+el.offsetY+'%;opacity:'+el.opacity+';';
